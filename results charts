      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import joblib\n",
        "import numpy as np\n",
        "\n",
        "# ========== Helper Functions ==========\n",
        "\n",
        "def plot_predictions_from_model(X_file, model_file, dataset_name, model_name):\n",
        "    \"\"\"Load preprocessed data + model (pkl) and plot predictions vs actuals + residuals\"\"\"\n",
        "    print(f\"\\n=== Predictions for {dataset_name} - {model_name} ===\")\n",
        "\n",
        "    # Load data\n",
        "    X = pd.read_csv(f\"/content/drive/MyDrive/MYResearchWork/{X_file}\")\n",
        "    model = joblib.load(f\"/content/drive/MyDrive/MYResearchWork/{model_file}\")\n",
        "\n",
        "    # Predictions\n",
        "    y_true = X[\"target\"] if \"target\" in X.columns else None\n",
        "    if y_true is None:\n",
        "        print(\"⚠️ No target column found in input file\")\n",
        "        return\n",
        "    X_features = X.drop(columns=[\"target\"])\n",
        "    y_pred = model.predict(X_features)\n",
        "\n",
        "    # Dataframe\n",
        "    df_pred = pd.DataFrame({\"Actual\": y_true, \"Predicted\": y_pred, \"Residuals\": y_true - y_pred})\n",
        "    print(df_pred.head())\n",
        "\n",
        "    # --- Plot Actual vs Predicted ---\n",
        "    plt.figure(figsize=(6,5))\n",
        "    sns.scatterplot(x=y_true, y=y_pred, alpha=0.7)\n",
        "    plt.plot([y_true.min(), y_true.max()], [y_true.min(), y_true.max()], \"r--\")\n",
        "    plt.title(f\"{dataset_name} - {model_name} (Actual vs Predicted)\")\n",
        "    plt.xlabel(\"Actual\")\n",
        "    plt.ylabel(\"Predicted\")\n",
        "    plt.show()\n",
        "\n",
        "    # --- Plot Residuals ---\n",
        "    plt.figure(figsize=(6,5))\n",
        "    sns.histplot(df_pred[\"Residuals\"], bins=20, kde=True, color=\"blue\")\n",
        "    plt.title(f\"{dataset_name} - {model_name} Residuals\")\n",
        "    plt.xlabel(\"Residuals\")\n",
        "    plt.ylabel(\"Frequency\")\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "def plot_predictions_from_csv(pred_file, dataset_name, model_name):\n",
        "    \"\"\"For CatBoost & Quantized models where predictions are already saved\"\"\"\n",
        "    print(f\"\\n=== Predictions for {dataset_name} - {model_name} ===\")\n",
        "\n",
        "    df = pd.read_csv(f\"/content/drive/MyDrive/MYResearchWork/{pred_file}\")\n",
        "    print(df.head())\n",
        "\n",
        "    # --- Actual vs Predicted ---\n",
        "    plt.figure(figsize=(6,5))\n",
        "    sns.scatterplot(x=df[\"Actual\"], y=df[\"Predicted\"], alpha=0.7)\n",
        "    plt.plot([df[\"Actual\"].min(), df[\"Actual\"].max()], [df[\"Actual\"].min(), df[\"Actual\"].max()], \"r--\")\n",
        "    plt.title(f\"{dataset_name} - {model_name} (Actual vs Predicted)\")\n",
        "    plt.xlabel(\"Actual\")\n",
        "    plt.ylabel(\"Predicted\")\n",
        "    plt.show()\n",
        "\n",
        "    # --- Residuals ---\n",
        "    df[\"Residuals\"] = df[\"Actual\"] - df[\"Predicted\"]\n",
        "    plt.figure(figsize=(6,5))\n",
        "    sns.histplot(df[\"Residuals\"], bins=20, kde=True, color=\"green\")\n",
        "    plt.title(f\"{dataset_name} - {model_name} Residuals\")\n",
        "    plt.xlabel(\"Residuals\")\n",
        "    plt.ylabel(\"Frequency\")\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "def plot_metrics(file, model_name, metric_type=\"default\"):\n",
        "    \"\"\"Plot metrics depending on dataset type\"\"\"\n",
        "    df = pd.read_csv(f\"/content/drive/MyDrive/MYResearchWork/{file}\")\n",
        "    print(f\"\\n=== Metrics for {model_name} ===\")\n",
        "    print(df)\n",
        "\n",
        "    if metric_type == \"linear\":\n",
        "        # RMSE, MAE, R2\n",
        "        for col in [\"RMSE\", \"MAE\", \"R2\"]:\n",
        "            plt.figure(figsize=(6,4))\n",
        "            sns.barplot(x=\"Dataset\", y=col, data=df)\n",
        "            plt.title(f\"{model_name} - {col}\")\n",
        "            plt.ylabel(col)\n",
        "            plt.show()\n",
        "\n",
        "    elif metric_type == \"quantized\":\n",
        "        # Test_MSE, Test_MAE, Test_R2\n",
        "        for col in [\"Test_MSE\", \"Test_MAE\", \"Test_R2\"]:\n",
        "            plt.figure(figsize=(6,4))\n",
        "            sns.barplot(x=\"Dataset\", y=col, hue=\"Model\", data=df)\n",
        "            plt.title(f\"{model_name} - {col}\")\n",
        "            plt.ylabel(col)\n",
        "            plt.show()\n",
        "    else:\n",
        "        # MSE, MAE, R2\n",
        "        for col in [\"MSE\", \"MAE\", \"R2\"]:\n",
        "            plt.figure(figsize=(6,4))\n",
        "            sns.barplot(x=\"Dataset\", y=col, data=df)\n",
        "            plt.title(f\"{model_name} - {col}\")\n",
        "            plt.ylabel(col)\n",
        "            plt.show()\n",
        "\n",
        "\n",
        "def plot_efficiency(file, model_name, dataset_filter=None):\n",
        "    \"\"\"Plot Training Time + Emissions (only if columns exist)\"\"\"\n",
        "    df = pd.read_csv(f\"/content/drive/MyDrive/MYResearchWork/{file}\")\n",
        "\n",
        "    # Adapt emissions file vs metrics file\n",
        "    if \"Training_Time_sec\" in df.columns and \"Emissions_kgCO2\" in df.columns:\n",
        "        # CatBoost style\n",
        "        pass\n",
        "    elif \"duration\" in df.columns and \"emissions\" in df.columns:\n",
        "        # emissions.csv style (Linear Regression runs)\n",
        "        df = df.rename(columns={\"duration\": \"Training_Time_sec\", \"emissions\": \"Emissions_kgCO2\", \"project_name\": \"Dataset\"})\n",
        "        df[\"Model\"] = model_name\n",
        "    else:\n",
        "        print(f\"⚠️ {file} has no training time/emissions data\")\n",
        "        return\n",
        "\n",
        "    if dataset_filter:\n",
        "        df = df[df[\"Dataset\"] == dataset_filter]\n",
        "\n",
        "    print(f\"\\n=== Efficiency Data for {model_name} ===\")\n",
        "    print(df[[\"Dataset\", \"Model\", \"Training_Time_sec\", \"Emissions_kgCO2\"]])\n",
        "\n",
        "    plt.figure(figsize=(7,5))\n",
        "    ax = sns.barplot(x=\"Dataset\", y=\"Training_Time_sec\", hue=\"Model\", data=df, alpha=0.6)\n",
        "    ax.set_ylabel(\"Training Time (s)\", color=\"purple\")\n",
        "    ax.set_title(f\"{model_name} - Training Time & CO₂ Emissions\")\n",
        "\n",
        "    ax2 = ax.twinx()\n",
        "    sns.lineplot(x=\"Dataset\", y=\"Emissions_kgCO2\", hue=\"Model\", data=df, marker=\"o\", ax=ax2, legend=False, color=\"red\")\n",
        "    ax2.set_ylabel(\"Emissions (kg CO₂)\", color=\"red\")\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# ========== Run for all models ==========\n",
        "\n",
        "# --- Linear Regression ---\n",
        "plot_metrics(\"Testing_Results.csv\", \"Linear Regression\", metric_type=\"linear\")\n",
        "plot_efficiency(\"emissions.csv\", \"Linear Regression\")\n",
        "\n",
        "# --- CatBoost ---\n",
        "plot_predictions_from_csv(\"Amazon_catboost_predictions.csv\", \"Amazon\", \"CatBoost\")\n",
        "plot_predictions_from_csv(\"Flipkart_catboost_predictions.csv\", \"Flipkart\", \"CatBoost\")\n",
        "plot_metrics(\"catboost_all_datasets_metrics.csv\", \"CatBoost\")\n",
        "plot_efficiency(\"catboost_all_datasets_metrics.csv\", \"CatBoost\")\n",
        "\n",
        "# --- Quantized CatBoost ---\n",
        "plot_metrics(\"CatBoost_Quantization_All_Test_Results.csv\", \"CatBoost Quantized\", metric_type=\"quantized\")\n"
      ],
