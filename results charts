      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ---------------------------\n",
        "# 1. Prepare the Results Data\n",
        "# ---------------------------\n",
        "\n",
        "linear_results = {\n",
        "    \"Dataset\": [\"Amazon\", \"Flipkart\"],\n",
        "    \"Model\": [\"Linear Regression\", \"Linear Regression\"],\n",
        "    \"RMSE\": [0.2663, 0.9249],\n",
        "    \"MAE\": [0.1595, 0.6475],\n",
        "    \"R2\": [0.8971, 0.1243],\n",
        "    \"Training_Time_sec\": [0.0307, 0.0123],\n",
        "    \"Emissions_kgCO2\": [1.81e-07, 6.38e-08]\n",
        "}\n",
        "\n",
        "catboost_results = {\n",
        "    \"Dataset\": [\"Amazon\", \"Flipkart\"],\n",
        "    \"Model\": [\"CatBoost\", \"CatBoost\"],\n",
        "    \"RMSE\": [0.04932**0.5, 0.12055**0.5],\n",
        "    \"MAE\": [0.1200, 0.1997],\n",
        "    \"R2\": [0.9284, 0.8766],\n",
        "    \"Training_Time_sec\": [1.518, 7.970],\n",
        "    \"Emissions_kgCO2\": [6.42e-06, 3.32e-05]\n",
        "}\n",
        "\n",
        "catboost_quant_results = {\n",
        "    \"Dataset\": [\"Amazon\", \"Flipkart\"],\n",
        "    \"Model\": [\"CatBoost Quantized (best)\", \"CatBoost Quantized (best)\"],\n",
        "    \"RMSE\": [5.24e-06**0.5, 0.03192**0.5],\n",
        "    \"MAE\": [0.00148, 0.1128],\n",
        "    \"R2\": [0.99999, 0.9681],\n",
        "    \"Training_Time_sec\": [0.979, 2.703],\n",
        "    \"Emissions_kgCO2\": [4.08e-06, 1.13e-05]\n",
        "}\n",
        "\n",
        "df = pd.concat([\n",
        "    pd.DataFrame(linear_results),\n",
        "    pd.DataFrame(catboost_results),\n",
        "    pd.DataFrame(catboost_quant_results)\n",
        "], ignore_index=True)\n",
        "\n",
        "# ---------------------------\n",
        "# 2. Helper Function for Bar Labels\n",
        "# ---------------------------\n",
        "def add_value_labels(ax, spacing=5, decimals=4):\n",
        "    \"\"\"Add value labels on top of bars.\"\"\"\n",
        "    for rect in ax.patches:\n",
        "        y_val = rect.get_height()\n",
        "        x_val = rect.get_x() + rect.get_width() / 2\n",
        "        label = f\"{y_val:.{decimals}f}\"\n",
        "        ax.annotate(label,\n",
        "                    (x_val, y_val),\n",
        "                    xytext=(0, spacing),\n",
        "                    textcoords=\"offset points\",\n",
        "                    ha=\"center\", va=\"bottom\",\n",
        "                    fontsize=9,\n",
        "                    bbox=dict(facecolor=\"white\", alpha=0.7, edgecolor=\"none\", boxstyle=\"round,pad=0.3\"))\n",
        "\n",
        "# ---------------------------\n",
        "# 3. Plotting Function\n",
        "# ---------------------------\n",
        "def plot_comparison(dataset_name):\n",
        "    data = df[df[\"Dataset\"] == dataset_name]\n",
        "\n",
        "    # ---- Show Table ----\n",
        "    print(f\"\\n=== Results for {dataset_name} ===\")\n",
        "    print(data.to_string(index=False))\n",
        "    print(\"=\" * 50)\n",
        "\n",
        "    # ---- RMSE ----\n",
        "    fig, ax = plt.subplots(figsize=(8, 6))\n",
        "    ax.bar(data[\"Model\"], data[\"RMSE\"], color=\"skyblue\", edgecolor=\"black\")\n",
        "    ax.set_title(f\"{dataset_name} - RMSE (Lower is Better)\", fontsize=14, fontweight=\"bold\")\n",
        "    ax.set_ylabel(\"RMSE\")\n",
        "    ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.7)\n",
        "    plt.xticks(rotation=20, ha=\"right\")\n",
        "    add_value_labels(ax, decimals=4)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # ---- MAE ----\n",
        "    fig, ax = plt.subplots(figsize=(8, 6))\n",
        "    ax.bar(data[\"Model\"], data[\"MAE\"], color=\"lightgreen\", edgecolor=\"black\")\n",
        "    ax.set_title(f\"{dataset_name} - MAE (Lower is Better)\", fontsize=14, fontweight=\"bold\")\n",
        "    ax.set_ylabel(\"MAE\")\n",
        "    ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.7)\n",
        "    plt.xticks(rotation=20, ha=\"right\")\n",
        "    add_value_labels(ax, decimals=4)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # ---- R² ----\n",
        "    fig, ax = plt.subplots(figsize=(8, 6))\n",
        "    ax.bar(data[\"Model\"], data[\"R2\"], color=\"orange\", edgecolor=\"black\")\n",
        "    ax.set_title(f\"{dataset_name} - R² (Closer to 1 is Better)\", fontsize=14, fontweight=\"bold\")\n",
        "    ax.set_ylabel(\"R² Score\")\n",
        "    ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.7)\n",
        "    plt.xticks(rotation=20, ha=\"right\")\n",
        "    add_value_labels(ax, decimals=4)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # ---- Training Time & Emissions ----\n",
        "    fig, ax1 = plt.subplots(figsize=(8, 6))\n",
        "    ax1.bar(data[\"Model\"], data[\"Training_Time_sec\"], color=\"mediumpurple\", alpha=0.7, edgecolor=\"black\")\n",
        "    ax1.set_ylabel(\"Training Time (s)\", color=\"mediumpurple\", fontsize=12)\n",
        "    ax1.set_title(f\"{dataset_name} - Training Time & CO₂ Emissions\", fontsize=14, fontweight=\"bold\")\n",
        "    ax1.grid(axis=\"y\", linestyle=\"--\", alpha=0.7)\n",
        "    plt.xticks(rotation=20, ha=\"right\")\n",
        "    add_value_labels(ax1, decimals=3)\n",
        "\n",
        "    ax2 = ax1.twinx()\n",
        "    ax2.plot(data[\"Model\"], data[\"Emissions_kgCO2\"], color=\"red\", marker=\"o\", linewidth=2, label=\"CO₂ Emissions\")\n",
        "    ax2.set_ylabel(\"Emissions (kg CO₂)\", color=\"red\", fontsize=12)\n",
        "\n",
        "    # Annotate emission values (shifted below to avoid overlap)\n",
        "    for i, val in enumerate(data[\"Emissions_kgCO2\"]):\n",
        "        ax2.annotate(f\"{val:.2e}\",\n",
        "                     (i, val),\n",
        "                     xytext=(0, -12),  # negative shift avoids overlap\n",
        "                     textcoords=\"offset points\",\n",
        "                     ha=\"center\",\n",
        "                     fontsize=9,\n",
        "                     bbox=dict(facecolor=\"white\", alpha=0.8, edgecolor=\"none\", boxstyle=\"round,pad=0.3\"))\n",
        "\n",
        "    fig.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "# ---------------------------\n",
        "# 4. Generate Plots\n",
        "# ---------------------------\n",
        "plot_comparison(\"Amazon\")\n",
        "plot_comparison(\"Flipkart\")\n"
      ],
